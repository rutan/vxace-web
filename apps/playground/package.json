{
  "name": "rpgmaker-vxace-web-playground",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "vite preview",
    "preprocess": "run-s build:i18n build:copy-template",
    "dev": "pnpm run preprocess && run-p --race dev:*",
    "dev:vite": "vite dev",
    "dev:i18n": "typesafe-i18n",
    "build": "run-s build:*",
    "build:i18n": "typesafe-i18n --no-watch",
    "build:copy-template": "node ./scripts/copyTemplate.ts",
    "build:vite": "vite build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint --type-aware",
    "lint:ts": "tsgo --noEmit",
    "format": "run-s format:*",
    "format:oxfmt": "oxfmt -c ../../.oxfmtrc.json",
    "format:oxlint": "oxlint --fix",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typesafe-i18n": "typesafe-i18n"
  },
  "dependencies": {
    "@rutan/rpgmaker-vxace-web-game-manifest": "workspace:*",
    "@rutan/rpgmaker-vxace-web-player-template": "workspace:*",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typesafe-i18n": "^5.27.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.2.4"
  }
}
