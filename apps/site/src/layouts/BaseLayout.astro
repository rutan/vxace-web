---
import type { I18nLang } from '$types';
import { SiteFooter, SiteHeader } from '$components';
import { getAlternatePaths, getLocalizedRoutePath, siteCopy, withBasePath, type PageId } from '$i18n';

type Props = {
  title: string;
  description: string;
  lang: I18nLang;
  page: PageId;
};

const { title, description, lang, page } = Astro.props;
const copy = siteCopy[lang];
const alternatePaths = getAlternatePaths(page);
const siteUrl = Astro.site ?? Astro.url;
const publicAssetPath = (path: string) => `${import.meta.env.BASE_URL}${path.replace(/^\/+/, '')}`;
const currentUrl = new URL(withBasePath(getLocalizedRoutePath(lang, page)), siteUrl).href;
const ogImageUrl = new URL(publicAssetPath(lang === 'ja' ? 'ogp_ja.jpg' : 'ogp_en.jpg'), siteUrl).href;
const faviconPath = publicAssetPath('favicon.svg');
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#f7f4ec" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#12171f" media="(prefers-color-scheme: dark)" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={copy.brand} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={currentUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="canonical" href={currentUrl} />
    <link rel="icon" type="image/svg+xml" href={faviconPath} />
    <link rel="alternate" hreflang="en" href={alternatePaths.en} />
    <link rel="alternate" hreflang="ja" href={alternatePaths.ja} />
    <link rel="alternate" hreflang="x-default" href={alternatePaths.xDefault} />
    <title>{title}</title>
    <script is:inline>
      if (localStorage.getItem('theme') === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.setAttribute('data-theme', 'dark');
      } else {
        document.documentElement.setAttribute('data-theme', 'light');
      }
    </script>
  </head>
  <body>
    <SiteHeader lang={lang} page={page} copy={copy.header} brand={copy.brand} />
    <main>
      <slot />
    </main>
    <SiteFooter copy={copy.footer} brand={copy.brand} />
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light dark;

    /* Layout */
    --page-max-width: 1120px;
    --page-gutter: clamp(20px, 5vw, 56px);
    --header-height: 72px;

    /* Radius */
    --radius-md: 8px;
    --radius-sm: 6px;

    /* Typography */
    font-family:
      Inter,
      ui-sans-serif,
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
    font-size: 16px;
    line-height: 1.7;

    /* Default theme */
    --color-bg: var(--theme-color-bg);
    --color-surface: var(--theme-color-surface);
    --color-surface-raised: var(--theme-color-surface-raised);
    --color-text: var(--theme-color-text);
    --color-muted: var(--theme-color-muted);
    --color-line: var(--theme-color-line);
    --color-line-strong: var(--theme-color-line-strong);
    --color-accent: var(--theme-color-accent);
    --color-accent-strong: var(--theme-color-accent-strong);
    --color-accent-contrast: var(--theme-color-accent-contrast);
    --color-warning: var(--theme-color-warning);
    --color-warning-line: var(--theme-color-warning-line);
    --color-warning-surface: var(--theme-color-warning-surface);
    --shadow-soft: var(--theme-shadow-soft);
    --shadow-header: var(--theme-shadow-header);

    /* Theme-independent */
    --color-hero-text: #ffffff;
    --color-hero-muted: rgb(255 255 255 / 78%);

    /* Light theme tokens */
    --light-color-bg: #f9f9f9;
    --light-color-surface: #fff;
    --light-color-surface-raised: #eee;
    --light-color-text: #222;
    --light-color-muted: #626b75;
    --light-color-line: #ddd4c4;
    --light-color-line-strong: #c6bbaa;
    --light-color-accent: #166b63;
    --light-color-accent-strong: #0f514b;
    --light-color-accent-contrast: #ffffff;
    --light-color-warning: #9a5a00;
    --light-color-warning-line: #d9a441;
    --light-color-warning-surface: #fff4d6;
    --light-shadow-soft: 0 24px 70px rgb(38 32 24 / 14%);
    --light-shadow-header: 0 1px 0 rgb(22 25 29 / 10%);

    /* Dark theme tokens */
    --dark-color-bg: #12171f;
    --dark-color-surface: #1c2530;
    --dark-color-surface-raised: #222d39;
    --dark-color-text: #eef2f5;
    --dark-color-muted: #aab4bf;
    --dark-color-line: #303b48;
    --dark-color-line-strong: #465360;
    --dark-color-accent: #55c5b6;
    --dark-color-accent-strong: #7dd8cc;
    --dark-color-accent-contrast: #0d171b;
    --dark-color-warning: #ffd37a;
    --dark-color-warning-line: #9d7023;
    --dark-color-warning-surface: #322819;
    --dark-shadow-soft: 0 24px 70px rgb(0 0 0 / 30%);
    --dark-shadow-header: 0 1px 0 rgb(255 255 255 / 8%);

    /* Active theme: light by default */
    --theme-color-bg: var(--light-color-bg);
    --theme-color-surface: var(--light-color-surface);
    --theme-color-surface-raised: var(--light-color-surface-raised);
    --theme-color-text: var(--light-color-text);
    --theme-color-muted: var(--light-color-muted);
    --theme-color-line: var(--light-color-line);
    --theme-color-line-strong: var(--light-color-line-strong);
    --theme-color-accent: var(--light-color-accent);
    --theme-color-accent-strong: var(--light-color-accent-strong);
    --theme-color-accent-contrast: var(--light-color-accent-contrast);
    --theme-color-warning: var(--light-color-warning);
    --theme-color-warning-line: var(--light-color-warning-line);
    --theme-color-warning-surface: var(--light-color-warning-surface);
    --theme-shadow-soft: var(--light-shadow-soft);
    --theme-shadow-header: var(--light-shadow-header);
  }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme]) {
      --theme-color-bg: var(--dark-color-bg);
      --theme-color-surface: var(--dark-color-surface);
      --theme-color-surface-raised: var(--dark-color-surface-raised);
      --theme-color-text: var(--dark-color-text);
      --theme-color-muted: var(--dark-color-muted);
      --theme-color-line: var(--dark-color-line);
      --theme-color-line-strong: var(--dark-color-line-strong);
      --theme-color-accent: var(--dark-color-accent);
      --theme-color-accent-strong: var(--dark-color-accent-strong);
      --theme-color-accent-contrast: var(--dark-color-accent-contrast);
      --theme-color-warning: var(--dark-color-warning);
      --theme-color-warning-line: var(--dark-color-warning-line);
      --theme-color-warning-surface: var(--dark-color-warning-surface);
      --theme-shadow-soft: var(--dark-shadow-soft);
      --theme-shadow-header: var(--dark-shadow-header);
    }
  }

  :root[data-theme="light"] {
    color-scheme: light;
  }

  :root[data-theme="dark"] {
    color-scheme: dark;

    --theme-color-bg: var(--dark-color-bg);
    --theme-color-surface: var(--dark-color-surface);
    --theme-color-surface-raised: var(--dark-color-surface-raised);
    --theme-color-text: var(--dark-color-text);
    --theme-color-muted: var(--dark-color-muted);
    --theme-color-line: var(--dark-color-line);
    --theme-color-line-strong: var(--dark-color-line-strong);
    --theme-color-accent: var(--dark-color-accent);
    --theme-color-accent-strong: var(--dark-color-accent-strong);
    --theme-color-accent-contrast: var(--dark-color-accent-contrast);
    --theme-color-warning: var(--dark-color-warning);
    --theme-color-warning-line: var(--dark-color-warning-line);
    --theme-color-warning-surface: var(--dark-color-warning-surface);
    --theme-shadow-soft: var(--dark-shadow-soft);
    --theme-shadow-header: var(--dark-shadow-header);
  }

  * {
    box-sizing: border-box;
  }

  html {
    background: var(--color-bg);
    color: var(--color-text);
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    min-width: 320px;
    background: var(--color-bg);
    color: var(--color-text);
    text-rendering: optimizeLegibility;
    -webkit-font-smoothing: antialiased;
  }

  body,
  button,
  input,
  textarea {
    font: inherit;
  }

  img {
    display: block;
    max-width: 100%;
  }

  a {
    color: inherit;
    text-decoration-color: color-mix(in srgb, currentColor 36%, transparent);
    text-underline-offset: 0.18em;
  }

  a:hover {
    text-decoration-color: currentColor;
  }

  main {
    min-height: calc(100svh - var(--header-height));
  }

  :focus-visible {
    outline: 3px solid color-mix(in srgb, var(--color-accent) 72%, white);
    outline-offset: 3px;
  }

  .page-shell {
    width: min(100% - (var(--page-gutter) * 2), var(--page-max-width));
    margin-inline: auto;
  }

  .button {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--color-line-strong);
    border-radius: var(--radius-sm);
    padding: 0.62rem 1rem;
    color: var(--color-text);
    font-weight: 700;
    line-height: 1.2;
    text-align: center;
    text-decoration: none;
    transition:
      background-color 160ms ease,
      border-color 160ms ease,
      color 160ms ease,
      transform 160ms ease;
  }

  .button:hover {
    transform: translateY(-1px);
  }

  .button.primary {
    border-color: var(--color-accent);
    background: var(--color-accent);
    color: var(--color-accent-contrast);
  }

  .button.primary:hover {
    background: var(--color-accent-strong);
    border-color: var(--color-accent-strong);
  }

  .button.secondary {
    background: color-mix(in srgb, var(--color-surface) 86%, transparent);
  }

  @media (max-width: 720px) {
    :root {
      --header-height: 64px;
    }

    .button {
      width: 100%;
    }
  }
</style>
