{
  "name": "rpgmaker-vxace-web-converter-app",
  "version": "0.1.0",
  "private": true,
  "author": "rutan",
  "type": "module",
  "main": "dist/main/index.js",
  "scripts": {
    "start": "electron-vite preview",
    "dev": "pnpm run build:i18n && run-p --race dev:*",
    "dev:electron": "electron-vite dev",
    "dev:i18n": "typesafe-i18n",
    "build": "run-s clean build:*",
    "build:i18n": "typesafe-i18n --no-watch",
    "build:electron": "electron-vite build",
    "package": "electron-forge package",
    "package:linux": "electron-forge package --platform linux --arch x64",
    "package:win": "electron-forge package --platform win32 --arch x64",
    "make": "electron-forge make --platform win32 --arch x64",
    "clean": "node ./scripts/clean.ts",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint --type-aware",
    "lint:ts": "tsgo --noEmit",
    "format": "run-s format:*",
    "format:oxfmt": "oxfmt -c ../../.oxfmtrc.json",
    "format:oxlint": "oxlint --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "typesafe-i18n": "typesafe-i18n"
  },
  "dependencies": {
    "@rutan/rpgmaker-vxace-web-converter-core": "workspace:*",
    "@rutan/rpgmaker-vxace-web-game-manifest": "workspace:*",
    "jotai": "^2.19.1",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typesafe-i18n": "^5.27.1",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/shared-types": "^7.11.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "electron": "^41.3.0",
    "electron-vite": "^5.0.0",
    "tailwindcss": "^4.2.4"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.33.1"
}
