{
  "$schema": "../node_modules/oxlint/configuration_schema.json",
  "env": {
    "browser": true,
    "es2024": true
  },
  "rules": {
    "no-undef": "off",
    "preserve-caught-error": "off",
    "typescript/no-explicit-any": "off",
    "no-unused-vars": [
      "error",
      {
        "argsIgnorePattern": "^_"
      }
    ]
  },
  "options": {
    "typeAware": true
  }
}
