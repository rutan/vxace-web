{
  "name": "@rutan/rpgmaker-vxace-web-player-template",
  "version": "0.0.2",
  "description": "Browser player template and RGSS3-compatible runtime for RPG Maker VX Ace Web.",
  "keywords": [
    "browser",
    "rgss3",
    "rpg-maker",
    "rpg-maker-vx-ace",
    "ruby-wasm",
    "runtime",
    "vxace",
    "web"
  ],
  "homepage": "https://github.com/rutan/vxace-web/tree/main/packages/player-template#readme",
  "bugs": {
    "url": "https://github.com/rutan/vxace-web/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rutan/vxace-web.git",
    "directory": "packages/player-template"
  },
  "files": [
    "dist/**/*"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite --port 8080",
    "build": "run-s build:*",
    "build:tsgo": "tsdown src/index.ts",
    "build:vite": "vite build",
    "preview": "vite preview",
    "test": "run-s test:unit test:browser",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:browser": "playwright test",
    "test:browser:headed": "playwright test --headed",
    "test:browser:debug": "playwright test --debug",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint src --type-aware",
    "lint:oxfmt": "oxfmt --check",
    "lint:ts": "tsgo --noEmit",
    "format": "run-s format:*",
    "format:oxfmt": "oxfmt -c ../../.oxfmtrc.json",
    "format:oxlint": "oxlint --fix"
  },
  "dependencies": {
    "@ruby/4.0-wasm-wasi": "2.9.3-2.9.4",
    "@rutan/rpgmaker-vxace-web-game-manifest": "workspace:*",
    "pixi.js": "7.4.3"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.33.1"
}
