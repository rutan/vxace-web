{
  "name": "@rutan/rpgmaker-vxace-web-game-manifest",
  "version": "0.1.0",
  "description": "Manifest schema and utilities for VX Ace Web Runtime.",
  "keywords": [
    "browser",
    "manifest",
    "rgss3",
    "rpg-maker",
    "rpg-maker-vx-ace",
    "vxace",
    "web"
  ],
  "homepage": "https://github.com/rutan/vxace-web/tree/main/packages/game-manifest#readme",
  "bugs": {
    "url": "https://github.com/rutan/vxace-web/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rutan/vxace-web.git",
    "directory": "packages/game-manifest"
  },
  "files": [
    "dist/**/*",
    "src/**/*"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown src/index.ts",
    "lint": "run-s lint:*",
    "lint:oxfmt": "oxfmt --check src tests package.json tsconfig.json",
    "lint:oxlint": "oxlint src tests --type-aware",
    "lint:ts": "tsgo --noEmit",
    "format": "run-s format:*",
    "format:oxfmt": "oxfmt -c ../../.oxfmtrc.json",
    "format:oxlint": "oxlint --fix",
    "test": "vitest run"
  }
}
