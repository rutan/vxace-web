{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "out/**", "template/**"]
    },
    "test": {
      "dependsOn": ["^build", "build"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "format": {},
    "dev": {
      "persistent": true,
      "cache": false
    }
  }
}
